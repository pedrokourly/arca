// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===============================================
// Modelos de Entidades Principais
// ===============================================

model Usuario {
  id_User   String  @id @default(uuid()) @map("ID_User") @db.Uuid
  nome      String  @db.VarChar(50)
  email     String  @unique @db.VarChar(100)
  senhaHash String  @map("SenhaHash") @db.VarChar(255)
  roleId    Int     @map("ID_Role") @db.SmallInt
  isActive  Boolean @default(true)

  role                      Role               @relation(fields: [roleId], references: [id_Role])
  logsExecutados            LogAuditoria[]     @relation("UsuarioExecutorLogs")
  atendimentoComoEstagiario Atendimento[]      @relation("EstagiarioAtendimentos")
  atendimentoComoSupervisor Atendimento[]      @relation("SupervisorAtendimentos")
  relatorioComoEstagiario   Prontuario[]    @relation("EstagiarioRelatorios")
  relatorioComoSupervisor   Prontuario[]    @relation("SupervisorRelatorios")

  @@map("USUARIOS")
}

model Role {
  id_Role   Int       @id @default(autoincrement()) @map("ID_Role") @db.SmallInt
  role      String    @db.VarChar(50)
  descricao String    @db.VarChar(255)
  usuarios  Usuario[]

  @@map("ROLES")
}

// ===============================================
// Modelos de Documentos e Logs
// ===============================================


model Prontuario {
  id_Documento  String              @id @default(uuid()) @map("ID_Documento") @db.Uuid
  id_Lista      String              @db.Uuid
  id_Estagiario String              @db.Uuid
  id_Supervisor String              @db.Uuid
  conteudo      String              @db.Text
  dataEmissao   DateTime            @default(now())
  status        StatusRelatorioEnum @default(PENDENTE)

  Lista      ListaEspera @relation(fields: [id_Lista], references: [id_Lista])
  estagiario Usuario     @relation("EstagiarioRelatorios", fields: [id_Estagiario], references: [id_User])
  supervisor Usuario     @relation("SupervisorRelatorios", fields: [id_Supervisor], references: [id_User])

  @@map("RELATORIOS_ALTA")
}

model LogAuditoria {
  id_Log                String   @id @default(uuid()) @map("ID_LOG") @db.Uuid
  id_Usuario_Executor   String   @db.Uuid
  nome_Usuario_Executor String   @db.VarChar(50)
  tipoAcao              String   @map("TipoAcao") @db.VarChar(100)
  entidade_Afetada      String?  @db.VarChar(50)
  id_Entidade_Afetada   String?  @db.VarChar(36)
  endereco_Ip           String?  @db.VarChar(45)
  acessoEm              DateTime @default(now())
  detalhes              Json?    @db.JsonB

  usuarioExecutor Usuario @relation("UsuarioExecutorLogs", fields: [id_Usuario_Executor], references: [id_User])

  @@map("LOGS_AUDITORIA")
}

model Atendimento {
  id_Atendimento         String   @id @default(uuid()) @map("ID_Atendimento") @db.Uuid
  dataHoraInicio         DateTime @db.Timestamp()
  dataHoraFim            DateTime @db.Timestamp()
  id_Lista               String   @db.Uuid
  id_Estagiario_Executor String   @db.Uuid
  id_Supervisor_Executor String   @db.Uuid
  id_Status              Int      @db.SmallInt @default(1)
  observacoes            String?   @db.Text

  ListaEspera        ListaEspera       @relation(fields: [id_Lista], references: [id_Lista], onDelete: Cascade)
  estagiarioExecutor Usuario           @relation("EstagiarioAtendimentos", fields: [id_Estagiario_Executor], references: [id_User])
  supervisorExecutor Usuario           @relation("SupervisorAtendimentos", fields: [id_Supervisor_Executor], references: [id_User])
  status             StatusAtendimento @relation(fields: [id_Status], references: [id_Status])

  @@map("ATENDIMENTOS")
}

model ListaEspera {
  id_Lista          String   @id @default(uuid()) @map("ID_Lista") @db.Uuid
  nomeRegistro      String   @db.VarChar(150)
  nomeSocial        String?  @db.VarChar(100)
  CPF               String   @db.Char(11) @default("")
  dataNascimento    DateTime @db.Date
  telefonePessoal   String   @db.VarChar(20)
  contatoEmergencia String   @db.VarChar(20)
  enderecoRua       String   @db.VarChar(255)
  enderecoNumero    String   @db.VarChar(10)
  enderecoBairro    String   @db.VarChar(100)
  enderecoCidade    String   @db.VarChar(100)
  enderecoEstado    String   @db.Char(2)
  enderecoCEP       String   @db.Char(8)
  createdAt         DateTime @default(now())
  id_Status         Int      @default(1)
  id_Genero         Int      @db.SmallInt
  id_Etnia          Int      @db.SmallInt
  id_Escolaridade   Int      @db.SmallInt

  genero        Genero          @relation(fields: [id_Genero], references: [id_Genero])
  Etnia         Etnia           @relation(fields: [id_Etnia], references: [id_Etnia])
  escolaridade  Escolaridade    @relation(fields: [id_Escolaridade], references: [id_Escolaridade])
  Status        StatusListaEspera    @relation(fields: [id_Status], references: [id_Status])
  Prontuario Prontuario[]
  Atendimento   Atendimento[]

  @@map("LISTA_ESPERA")
}

// ===============================================
// Modelos de Tabelas de Apoio (Lookup Tables)
// ===============================================

model Genero {
  id_Genero Int    @id @default(autoincrement()) @map("ID_Genero") @db.SmallInt
  nome      String @db.VarChar

  listaEspera ListaEspera[]

  @@map("GENERO")
}

model Etnia {
  id_Etnia Int    @id @default(autoincrement()) @map("ID_Etnia") @db.SmallInt
  nome     String @db.VarChar

  listaEspera ListaEspera[]

  @@map("ETNIA")
}

model Escolaridade {
  id_Escolaridade Int    @id @default(autoincrement()) @map("ID_Escolaridade") @db.SmallInt
  nome            String @db.VarChar

  listaEspera ListaEspera[]

  @@map("ESCOLARIDADES")
}

model StatusListaEspera {
  id_Status     Int       @id @default(autoincrement()) @map("ID_Status") @db.SmallInt
  nome          String    @db.VarChar

  listaEspera ListaEspera[]

  @@map("STATUS_LISTA_ESPERA")
}
model StatusAtendimento {
  id_Status    Int           @id @default(autoincrement()) @map("ID_Status") @db.SmallInt
  nome         String        @db.VarChar

  atendimentos Atendimento[]

  @@map("STATUS_ATENDIMENTO")
}

// ===============================================
// Tipos ENUM
// ===============================================

enum StatusRelatorioEnum {
  PENDENTE
  EMITIDO
  CANCELADO
  // Adicione outros status conforme necessário
}

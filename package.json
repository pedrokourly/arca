{
  "name": "arca",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "concurrently -k -n backend,frontend -c magenta,cyan \"cross-env PORT=3333 npm run -w backend start:dev\" \"npm run -w frontend dev\"",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "next-auth": "^4.24.11"
  }
}
